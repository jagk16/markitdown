# Obligatorio: token de Vercel Blob (se crea al conectar Storage → Blob al proyecto)
BLOB_READ_WRITE_TOKEN=

# Opcional: Vercel lo añade automáticamente al conectar Blob
BLOB_STORE_ID=

# public = URLs directas (recomendado para esta app temporal)
# private = más seguro; descarga vía /api/download
BLOB_ACCESS_MODE=public
NEXT_PUBLIC_BLOB_ACCESS_MODE=public

# Límite de tamaño por archivo (MB)
MAX_FILE_SIZE_MB=25
